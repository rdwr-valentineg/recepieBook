# Copy to .env and fill in.
# In k8s: create a Secret from this and reference it as envFrom in the deployment.

# ---- Required ----

DATABASE_URL=mariadb+pymysql://recipes:CHANGEME@mariadb.home.example.com:3306/recipes
APP_PASSWORD=choose-a-strong-family-password
SESSION_SECRET=generate-with-openssl-rand-hex-32

# ---- LLM providers (at least one required for URL extraction) ----

ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001   # override if desired

OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ---- Hosting ----

# Absolute base URL used for share links sent to people outside your network.
SHARE_BASE_URL=https://example.com

# Set to True when running behind HTTPS (nginx-ingress with TLS termination).
SECURE_COOKIES=True

# ---- Optional tuning ----

# SESSION_MAX_AGE_DAYS=60
# FETCH_TIMEOUT_SECONDS=30
# LLM_TIMEOUT_SECONDS=90
# CAPTURE_TIMEOUT_SECONDS=60
# MAX_IMAGE_SIZE_MB=8
