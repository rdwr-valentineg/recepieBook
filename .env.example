# Copy to .env and fill in values.
# In k8s: kubectl create secret generic recipe-book-secret --from-env-file=.env

# ── Required ─────────────────────────────────────────────────────────────────
DATABASE_URL=mariadb+pymysql://recipes:CHANGEME@mariadb.home.example.com:3306/recipes
APP_PASSWORD=choose-a-strong-family-password
SESSION_SECRET=run: openssl rand -hex 32

# ── LLM providers — set at least one ─────────────────────────────────────────

# Google Gemini Flash — FREE (15 req/min, 1M tokens/day)
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.0-flash

# Groq — FREE (fast, vision supported)
# Get key: https://console.groq.com
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_VISION_MODEL=llama-3.2-11b-vision-preview

# Ollama — SELF-HOSTED, completely free
# Deploy in k8s alongside this app (see README)
# OLLAMA_BASE_URL=http://ollama:11434/v1
# OLLAMA_MODEL=gemma3:4b
# OLLAMA_VISION_MODEL=llava:7b

# OpenAI — paid
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Anthropic — paid
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Hosting ───────────────────────────────────────────────────────────────────
SHARE_BASE_URL=https://example.com
SECURE_COOKIES=True

# ── Optional tuning ───────────────────────────────────────────────────────────
# CAPTURE_TIMEOUT_SECONDS=120
# LLM_TIMEOUT_SECONDS=120
# MAX_IMAGE_SIZE_MB=8
