# Copy to .env and fill in values.
# kubectl create secret generic recipe-book-secret --from-env-file=.env

DATABASE_URL=mariadb+pymysql://recipes:CHANGEME@mariadb.home.example.com:3306/recipes
APP_PASSWORD=choose-a-strong-password
SESSION_SECRET=run: openssl rand -hex 32
SHARE_BASE_URL=https://example.com
SECURE_COOKIES=True

# ── Direct providers (tried in this order) ───────────────────────────────────

# Claude — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# GPT — https://platform.openai.com
OPENAI_API_KEY=sk-...

# Grok — https://console.x.ai (free monthly credits, has vision)
XAI_API_KEY=xai-...

# Gemini — https://aistudio.google.com/apikey (free tier, may need billing linked)
GEMINI_API_KEY=AIza...

# Groq — https://console.groq.com (fast, free tier)
GROQ_API_KEY=gsk_...

# ── Fallback providers ────────────────────────────────────────────────────────

# OpenRouter — https://openrouter.ai (catch-all fallback)
# Uses "openrouter/free" — OpenRouter's smart router that auto-picks
# whichever free model is available, including vision. Always up to date.
OPENROUTER_API_KEY=sk-or-...
# Override only if you want specific models:
# OPENROUTER_TEXT_MODELS=google/gemma-2-9b-it:free
# OPENROUTER_VISION_MODELS=meta-llama/llama-3.2-11b-vision-instruct:free


# ── Optional tuning ───────────────────────────────────────────────────────────
# CAPTURE_TIMEOUT_SECONDS=120
# LLM_TIMEOUT_SECONDS=90
